{
  "name": "uplifting-2",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "api": "bun --filter api",
    "mobile": "bun --filter mobile",
    "release": "bash apps/mobile/scripts/release-ios.sh",
    "release:ios": "bash apps/mobile/scripts/release-ios.sh",
    "testflight": "bash apps/mobile/scripts/testflight.sh",
    "changelog": "bun scripts/generate-changelog.ts",
    "changelog:dry": "bun scripts/generate-changelog.ts --dry-run",
    "bump": "bun scripts/bump-version.ts",
    "lint": "bunx oxlint .",
    "fmt": "bunx oxfmt --write .",
    "fmt:check": "bunx oxfmt --check .",
    "postinstall": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0"
  }
}
